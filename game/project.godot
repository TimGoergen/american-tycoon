; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the format is simple text so manual edits are safe.

config_version=5

[application]

config/name="American Tycoon"
config/description="Idle/tycoon — M1 The Slice"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.5", "Mobile")
config/tags=PackedStringArray("game")

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
