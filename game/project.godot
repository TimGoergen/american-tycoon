; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="American Tycoon"
config/description="Idle/tycoon — M1 The Slice"
config/tags=PackedStringArray("game")
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://art/branding/american_tycoon_logo.png"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/resizable=false
window/size/window_width_override=495
window/size/window_height_override=880
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[gui]

; Pixels a touch must travel before a ScrollContainer treats it as a scroll rather
; than a click. The default (0) means a finger that lands on a button never scrolls
; the list — so the property ladder couldn't be swiped on the phone. A small
; threshold lets a drag scroll even when it starts on a row's button.
common/default_scroll_deadzone=30

[dotnet]

project/assembly_name="American Tycoon"

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
